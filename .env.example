# QuantAI environment variables
# Copy this file to .env and fill in your values

# Secret key for JWT tokens (change this to a long random string in production)
QUANTAI_SECRET=your-secret-key-change-this

# API port (default 8000)
PORT=8000

# Telegram bot (optional — for signal alerts)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
